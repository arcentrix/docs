{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Arcentra Documentation",
  "colors": {
    "primary": "#0A0A0A",
    "light": "#111827",
    "dark": "#F5F5F5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "tabs": [
          {
            "tab": "Guides",
            "openapi": "en/api-reference/openapi.json",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "en/index",
                  "en/quickstart",
                  "en/development"
                ]
              },
              {
                "group": "Concepts",
                "pages": [
                  "en/architecture",
                  "en/pipelines"
                ]
              },
              {
                "group": "Operate",
                "pages": [
                  "en/configuration"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "en/api-reference/introduction"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "zh-Hans",
        "tabs": [
          {
            "tab": "指南",
            "openapi": "en/api-reference/openapi.json",
            "groups": [
              {
                "group": "快速开始",
                "pages": [
                  "zh/index",
                  "zh/quickstart",
                  "zh/development"
                ]
              },
              {
                "group": "核心概念",
                "pages": [
                  "zh/architecture",
                  "zh/pipelines"
                ]
              },
              {
                "group": "运维",
                "pages": [
                  "zh/configuration"
                ]
              }
            ]
          },
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "概览",
                "pages": [
                  "zh/api-reference/introduction"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo.svg",
    "dark": "/logo/logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@arcentra.co"
      },
      {
        "type": "github",
        "href": "https://github.com/arcentrix/arcentra"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/arcentrix/arcentra"
    }
  },
  "description": "Arcentra Documentation",
  "appearance": {
    "default": "system"
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  }
}
