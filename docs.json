{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Arcentra Documentation",
  "colors": {
    "primary": "#0A0A0A",
    "light": "#111827",
    "dark": "#F5F5F5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "openapi": "/en/api-reference/openapi.json",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "essentials/settings",
                  "essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/reusable-snippets"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "zh-Hans",
        "openapi": "/zh/api-reference/openapi.json",
        "tabs": [
          {
            "tab": "指南",
            "groups": [
              {
                "group": "快速开始",
                "pages": [
                  "zh/index",
                  "zh/quickstart",
                  "zh/development"
                ]
              },
              {
                "group": "自定义",
                "pages": [
                  "zh/essentials/settings",
                  "zh/essentials/navigation"
                ]
              },
              {
                "group": "编写内容",
                "pages": [
                  "zh/essentials/markdown",
                  "zh/essentials/code",
                  "zh/essentials/images",
                  "zh/essentials/reusable-snippets"
                ]
              }
            ]
          },
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "API 文档",
                "pages": [
                  "zh/api-reference/introduction"
                ]
              },
              {
                "group": "接口示例",
                "pages": [
                  "zh/api-reference/endpoint/get",
                  "zh/api-reference/endpoint/create",
                  "zh/api-reference/endpoint/delete",
                  "zh/api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo.svg",
    "dark": "/logo/logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@arcentra.co"
      },
      {
      "type": "github",
      "href": "https://github.com/arcentrix/arcentra"
    }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/arcentrix/arcentra"
    }
  },
  "description": "Arcentra Documentation",
  "appearance": {
    "default": "system"
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  }
}